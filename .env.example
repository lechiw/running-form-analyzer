# Running Form Analyzer - LLM API Configuration
#
# Set at least one of these to enable AI-powered analysis reports.
# The report quality improves significantly with LLM integration.

# DeepSeek (recommended - cheaper, Chinese-optimized)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI (alternative)
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: specify provider (deepseek or openai, default: deepseek)
# LLM_PROVIDER=deepseek
